+/**
+ * Marks a Stroke as having been drawn with the arrow tool (single or double-ended), so that its
+ * arrowhead(s) can be regenerated (e.g. after a resize) instead of being naively affine-transformed,
+ * which would otherwise distort them under non-uniform scaling. NONE for any regular stroke.
+ */
+class ArrowKind {
+public:
+    enum Value { NONE, SINGLE, DOUBLE };
+    static constexpr std::array<const char8_t*, 3> NAMES = {u8"none", u8"single", u8"double"};
+    ArrowKind(Value v): value(v) {}
+
+    operator const Value&() const { return value; }
+    operator Value&() { return value; }
+
+private:
+    Value value = NONE;
+};
