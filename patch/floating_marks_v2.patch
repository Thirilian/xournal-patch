+/**
+ * If the mouse pointer is currently over a page, returns that page's XojPageView along with the
+ * pointer's position on that page, in document units (matching Element::setX/setY's convention).
+ * Returns nullptr if the pointer isn't over the canvas or isn't over any page (e.g. paste
+ * triggered via a keyboard shortcut while the mouse happens to be elsewhere on screen).
+ */
+static XojPageView* getPageViewAndPosUnderCursor(XournalView* xournal, double& outX, double& outY) {
+    GtkWidget* widget = xournal->getWidget();
+    GdkWindow* window = gtk_widget_get_window(widget);
+    if (!window) {
+        return nullptr;
+    }
+
+    GdkDisplay* display = gdk_display_get_default();
+    GdkSeat* seat = display ? gdk_display_get_default_seat(display) : nullptr;
+    GdkDevice* pointer = seat ? gdk_seat_get_pointer(seat) : nullptr;
+    if (!pointer) {
+        return nullptr;
+    }
+
+    gint widgetX = 0;
+    gint widgetY = 0;
+    GdkModifierType mask;
+    gdk_window_get_device_position(window, pointer, &widgetX, &widgetY, &mask);
+
+    // Convert from viewport-relative to layout-absolute pixel coordinates (same convention as
+    // InputEvent::relative, see AbstractInputHandler::getPageAtCurrentPosition()).
+    GtkXournal* gtkXournal = GTK_XOURNAL(widget);
+    double layoutX = widgetX + (gtkXournal->hadjustment ? gtk_adjustment_get_value(gtkXournal->hadjustment) : 0.0);
+    double layoutY = widgetY + (gtkXournal->vadjustment ? gtk_adjustment_get_value(gtkXournal->vadjustment) : 0.0);
+
+    XojPageView* pageView = xournal->getLayout()->getPageViewAt(static_cast<int>(layoutX), static_cast<int>(layoutY));
+    if (!pageView) {
+        return nullptr;
+    }
+
+    auto pagePos = pageView->getPixelPosition();
+    double zoom = xournal->getZoom();
+    outX = (layoutX - pagePos.x) / zoom;
+    outY = (layoutY - pagePos.y) / zoom;
+    return pageView;
+}
+
+/**
+ * Grabs the given (just-created) selection at its own center and puts it into "moving" state, so
+ * that it follows the mouse pointer on every subsequent motion event (see the handleSelectionMove
+ * branch in PenInputHandler::actionMotion(), which moves any selection whose isMoving() is true,
+ * regardless of whether a mouse button is actually held down). The very next click on the canvas
+ * then finalizes its position and page, exactly like ending a normal click-and-drag - no further
+ * code is needed for that part, it is already handled by the existing selection-click logic in
+ * PenInputHandler::actionStart()/actionEnd().
+ */
+static void beginFloatingPlacement(EditSelection* selection) {
+    double zoom = selection->getView()->getXournal()->getZoom();
+    double grabX = zoom * (selection->getXOnView() + selection->getWidth() / 2);
+    double grabY = zoom * (selection->getYOnView() + selection->getHeight() / 2);
+    selection->mouseDown(CURSOR_SELECTION_MOVE, grabX, grabY);
+}
+
+/**
+ * Half-extent (in document points) of the cross mark, i.e. the diagonal reaches this far from the
+ * center in each direction. Total visual span of the cross is 2 * CROSS_MARK_SIZE.
+ */
+constexpr double CROSS_MARK_SIZE = 2.5;
+
+/**
+ * Half-length (in document points) of the tick marks. Total length of a tick is 2 * TICK_MARK_SIZE.
+ */
+constexpr double TICK_MARK_SIZE = 3.;
+
+/**
+ * Creates a small Stroke (a cross or a tick mark, depending on localOffsets) using the currently
+ * selected tool's color and thickness, spawns it under the mouse pointer (or at the center of the
+ * visible area if the pointer isn't over any page), and attaches it to the pointer until the next
+ * left click - same mechanism as clipboardPaste()/clipboardPasteXournal() above.
+ * localOffsets are pairs of (dx, dy), in document points, relative to the spawn point.
+ */
+static void createFloatingMark(Control* ctrl, XournalView* xournal,
+                                const std::vector<std::pair<double, double>>& localOffsets) {
+    double x = 0;
+    double y = 0;
+    XojPageView* view = getPageViewAndPosUnderCursor(xournal, x, y);
+    if (!view) {
+        auto pageNr = ctrl->getCurrentPageNo();
+        if (pageNr == npos) {
+            return;
+        }
+        view = xournal->getViewFor(pageNr);
+        if (!view) {
+            return;
+        }
+        xournal->getPasteTarget(x, y);
+    }
+
+    ToolHandler* toolHandler = ctrl->getToolHandler();
+    auto stroke = std::make_unique<Stroke>();
+    if (toolHandler->isDrawingTool()) {
+        stroke->setWidth(toolHandler->getThickness());
+        stroke->setColor(toolHandler->getColor());
+    } else {
+        // The active tool has no thickness of its own (e.g. a selection tool, the hand tool...),
+        // which would otherwise produce an invisible 0-width stroke. Fall back to the pen's
+        // settings, same as GeometryToolController::markOrigin() does.
+        stroke->setWidth(toolHandler->getToolThickness(TOOL_PEN)[TOOL_SIZE_FINE]);
+        stroke->setColor(toolHandler->getTool(TOOL_PEN).getColor());
+    }
+    for (auto&& [dx, dy]: localOffsets) {
+        stroke->addPoint(Point(x + dx, y + dy));
+    }
+
+    Document* doc = ctrl->getDocument();
+    doc->lock_shared();
+    PageRef page = view->getPage();
+    Layer* layer = page->getSelectedLayer();
+    doc->unlock_shared();
+
+    UndoRedoHandler* undoRedo = ctrl->getUndoRedoHandler();
+    Stroke* rawStroke = stroke.get();
+    undoRedo->addUndoAction(std::make_unique<InsertUndoAction>(page, layer, rawStroke));
+    auto sel = SelectionFactory::createFromFloatingElement(ctrl, page, layer, view, std::move(stroke));
+
+    EditSelection* selection = sel.release();
+    xournal->setSelection(selection);
+    beginFloatingPlacement(selection);
+}
+
+void Control::insertCross() {
+    createFloatingMark(this, win->getXournal(),
+                        {{CROSS_MARK_SIZE, CROSS_MARK_SIZE},
+                         {-CROSS_MARK_SIZE, -CROSS_MARK_SIZE},
+                         {0, 0},
+                         {CROSS_MARK_SIZE, -CROSS_MARK_SIZE},
+                         {-CROSS_MARK_SIZE, CROSS_MARK_SIZE}});
+}
+
+void Control::insertTickHorizontal() {
+    createFloatingMark(this, win->getXournal(), {{-TICK_MARK_SIZE, 0}, {TICK_MARK_SIZE, 0}});
+}
+
+void Control::insertTickVertical() {
+    createFloatingMark(this, win->getXournal(), {{0, -TICK_MARK_SIZE}, {0, TICK_MARK_SIZE}});
+}
