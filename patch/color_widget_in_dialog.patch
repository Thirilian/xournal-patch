 #include "IntEdLatexDialog.h"
 
+#include <array>    // for std::array
 #include <sstream>  // for operator<<, basic_ostream
 #include <utility>  // for move
 
@@ -27,10 +28,14 @@
 #include <gtksourceview/gtksource.h>  // for GTK_SOURCE_VIEW, gtk_sou...
 #endif
 
+#include "control/Control.h"
 #include "control/LatexController.h"
+#include "control/Tool.h"
+#include "control/ToolHandler.h"
 #include "control/settings/LatexSettings.h"  // for LatexSettings
 #include "gui/Builder.h"
 #include "model/Font.h"        // for XojFont
+#include "util/Color.h"        // for rgb_to_GdkRGBA, GdkRGBA_to_argb
 #include "util/StringUtils.h"  // for replace_pair, StringUtils
 #include "util/raii/CStringWrapper.h"
 
@@ -49,6 +54,46 @@ IntEdLatexDialog::IntEdLatexDialog(GladeSearchpath* gladeSearchPath, std::unique
 
     populateStandardWidgetsFromBuilder(builder);
 
+    /*
+     * Color button: lets the user change the formula's color without leaving/closing this dialog
+     * (the dialog is modal, so the main window's toolbar color picker is otherwise unreachable).
+     * Changing it updates the TOOL_LATEX tool color (the same one read at compile time) and
+     * triggers a recompile so the preview reflects the new color immediately.
+     */
+    GtkColorButton* colorButton = GTK_COLOR_BUTTON(builder.get("btColor"));
+    Control* ctrlPtr = texCtrl->control;
+    GdkRGBA initialColor = Util::rgb_to_GdkRGBA(ctrlPtr->getToolHandler()->getTool(TOOL_LATEX).getColor());
+    gtk_color_chooser_set_rgba(GTK_COLOR_CHOOSER(colorButton), &initialColor);
+
+    // The Xournal Palette (xournal.gpl), added as a custom section in the color button's popover.
+    // This does not affect the dialog's width: the palette lives in a popup, not inline.
+    static const std::array<GdkRGBA, 12> xournalPalette = {
+            Util::rgb_to_GdkRGBA(Color(0xff000000U)),  // Black
+            Util::rgb_to_GdkRGBA(Color(0xff008000U)),  // Green
+            Util::rgb_to_GdkRGBA(Color(0xff00c0ffU)),  // Light Blue
+            Util::rgb_to_GdkRGBA(Color(0xff00ff00U)),  // Light Green
+            Util::rgb_to_GdkRGBA(Color(0xff3333ccU)),  // Blue
+            Util::rgb_to_GdkRGBA(Color(0xff808080U)),  // Gray
+            Util::rgb_to_GdkRGBA(Color(0xff823c9bU)),  // Purple
+            Util::rgb_to_GdkRGBA(Color(0xffff0000U)),  // Red
+            Util::rgb_to_GdkRGBA(Color(0xffff00ffU)),  // Magenta
+            Util::rgb_to_GdkRGBA(Color(0xffff8000U)),  // Orange
+            Util::rgb_to_GdkRGBA(Color(0xffffc800U)),  // Yellow
+            Util::rgb_to_GdkRGBA(Color(0xffffffffU)),  // White
+    };
+    gtk_color_chooser_add_palette(GTK_COLOR_CHOOSER(colorButton), GTK_ORIENTATION_HORIZONTAL, 6,
+                                   static_cast<int>(xournalPalette.size()), const_cast<GdkRGBA*>(xournalPalette.data()));
+
+    g_signal_connect(colorButton, "color-set", G_CALLBACK(+[](GtkColorButton* btn, gpointer d) {
+                         auto texCtrl = static_cast<LatexController*>(d);
+                         GdkRGBA newColor;
+                         gtk_color_chooser_get_rgba(GTK_COLOR_CHOOSER(btn), &newColor);
+                         texCtrl->control->getToolHandler()->getTool(TOOL_LATEX).setColor(
+                                 Util::GdkRGBA_to_argb(newColor));
+                         LatexController::handleTexChanged(texCtrl);
+                     }),
+                     texCtrl.get());
+
 #ifdef ENABLE_GTK_SOURCEVIEW
     this->texBox = gtk_source_view_new();
 #else
