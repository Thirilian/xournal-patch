index 183c5d937..2013f4d40 100644
--- a/src/core/control/tools/EditSelection.cpp
+++ b/src/core/control/tools/EditSelection.cpp
@@ -260,6 +260,189 @@ EditSelection::~EditSelection() {
     finalizeSelection();
 }
 
+/**
+ * Patch 15.2: pixel tolerance (in document points, independent of zoom) within which the arrowhead's
+ * tip snaps to the nearest point on another stroke's path. Deliberately a plain, independent
+ * constant here - not shared with alignment_snap's own tolerance setting (if that separate,
+ * independent patch series happens to be applied too), since this is an unrelated snapping
+ * mechanism (a single point onto a stroke's path, not a bounding box edge/center onto another's).
+ */
+constexpr double ARROWHEAD_SNAP_TOLERANCE = 8.0;
+
+/**
+ * Returns the closest point to `p` lying on the segment [a, b] (clamped to the segment, not the
+ * infinite line through it).
+ */
+static auto closestPointOnSegment(const Point& p, const Point& a, const Point& b) -> Point {
+    double abx = b.x - a.x;
+    double aby = b.y - a.y;
+    double lengthSq = abx * abx + aby * aby;
+    if (lengthSq < 1e-9) {
+        return a;  // degenerate (zero-length) segment
+    }
+    double t = ((p.x - a.x) * abx + (p.y - a.y) * aby) / lengthSq;
+    t = std::clamp(t, 0.0, 1.0);
+    return Point(a.x + t * abx, a.y + t * aby);
+}
+
+/// Normalizes an angle, in radians, into (-pi, pi].
+static auto normalizeAngle(double a) -> double {
+    while (a <= -M_PI) {
+        a += 2 * M_PI;
+    }
+    while (a > M_PI) {
+        a -= 2 * M_PI;
+    }
+    return a;
+}
+
+/**
+ * Patch 15.11: true if the given raw direction angle (atan2(dy, dx), this document's Y-down space)
+ * falls within the "normal" (non-inverted) arrowhead mode's allowed half of the compass - visually:
+ * from just past "left" (exclusive) through "up" to "right" (inclusive). The complementary half (used
+ * when the arrowhead is in "inverted" mode, see Stroke::isArrowHeadInverted()) is everything else:
+ * from just past "right" (exclusive) through "down" to "left" (inclusive). The two halves are exact
+ * diametric opposites of one another, split along the horizontal ("left"-"right") axis.
+ */
+static auto isNormalModeAngle(double rawAngle) -> bool {
+    constexpr double UP = -(M_PI / 2);
+    double rel = normalizeAngle(rawAngle - UP);
+    return rel > -(M_PI / 2) && rel <= (M_PI / 2);
+}
+
+void EditSelection::snapArrowHeadTip(double& dx, double& dy) {
+    auto elements = this->getElementsView();
+    if (elements.size() != 1) {
+        return;
+    }
+    const auto* stroke = dynamic_cast<const Stroke*>(*elements.begin());
+    if (!stroke || !stroke->hasSnappableTip() || stroke->getPointCount() < 3) {
+        return;
+    }
+
+    // Patch 15.4: CORRECTIF - EditSelection's own (x, y, width, height) is a PADDED view of the
+    // element's true bounds (see the constructor: a fixed 12-point margin added symmetrically on
+    // every side, "so anchors do not collapse even for horizontal/vertical strokes"). Mixing this
+    // padded x/y with the stroke's own unpadded getElementWidth()/Height() (patch 15.3's bug) shifted
+    // the computed center away from the true visual center by roughly that padding amount. Since the
+    // padding is symmetric, using this->width/height instead (which carry that exact same padding)
+    // cancels it out correctly: this->x + this->width / 2 always equals the element's own true
+    // center, regardless of the padding's actual value.
+    Point prospectiveTip{this->x + this->width / 2 + dx, this->y + this->height / 2 + dy};
+
+    Point best = prospectiveTip;
+    Point bestSegA{};
+    Point bestSegB{};
+    double bestDistSq = ARROWHEAD_SNAP_TOLERANCE * ARROWHEAD_SNAP_TOLERANCE;
+    bool found = false;
+    for (auto& elPtr: this->sourceLayer->getElements()) {
+        const Element* other = elPtr.get();
+        if (other == stroke) {
+            continue;
+        }
+        const auto* otherStroke = dynamic_cast<const Stroke*>(other);
+        if (!otherStroke) {
+            continue;
+        }
+        const auto& pts = otherStroke->getPointVector();
+        for (size_t i = 0; i + 1 < pts.size(); ++i) {
+            Point candidate = closestPointOnSegment(prospectiveTip, pts[i], pts[i + 1]);
+            double ddx = candidate.x - prospectiveTip.x;
+            double ddy = candidate.y - prospectiveTip.y;
+            double distSq = ddx * ddx + ddy * ddy;
+            if (distSq < bestDistSq) {
+                bestDistSq = distSq;
+                best = candidate;
+                bestSegA = pts[i];
+                bestSegB = pts[i + 1];
+                found = true;
+            }
+        }
+    }
+
+    if (found) {
+        dx += best.x - prospectiveTip.x;
+        dy += best.y - prospectiveTip.y;
+    }
+
+    // Patch 15.5/15.6: keep the arrowhead's own orientation in sync with the tangent of whichever
+    // segment it is (now) snapped to - see this method's own doc comment in the header for the full
+    // rule.
+    //
+    // Patch 15.9: CORRECTIF - the invisible vector (center to tip) must always be the reference for
+    // "up"/"down"/direction, which means it must be measured from the stroke's OWN CURRENT raw
+    // points, not assumed to always be -pi/2 ("up"). That assumption only holds for a
+    // freshly-spawned arrowhead: once a previous rotate-and-finalize cycle has baked a rotation into
+    // the raw points (from an earlier drag-and-snap, or an earlier "R" press), the raw tip no longer
+    // points up on its own - and this->rotation resets to 0 on every brand-new EditSelection (e.g.
+    // right after a deselect then re-select), so treating it as "relative to a fixed up" produced a
+    // mismatched orientation as soon as the arrowhead was re-selected. rawTipAngle below is
+    // recomputed fresh every time instead, directly from the three points as they currently stand.
+    constexpr double UP_ABS = -(M_PI / 2);
+    constexpr double DOWN_ABS = M_PI / 2;
+    bool inverted = stroke->isArrowHeadInverted();
+    Point rawTip = stroke->getPoint(1);
+    Point rawLegA = stroke->getPoint(0);
+    Point rawLegB = stroke->getPoint(2);
+    Point rawCenter{(rawLegA.x + rawLegB.x) / 2, (rawLegA.y + rawLegB.y) / 2};
+    double rawTipAngle = std::atan2(rawTip.y - rawCenter.y, rawTip.x - rawCenter.x);
+    if (!found) {
+        this->rotation = (inverted ? DOWN_ABS : UP_ABS) - rawTipAngle;
+        this->arrowHeadWasSnapped = false;
+        return;
+    }
+
+    double tangentA = std::atan2(bestSegB.y - bestSegA.y, bestSegB.x - bestSegA.x);
+    double tangentB = normalizeAngle(tangentA + M_PI);
+    double chosen;
+    if (!this->arrowHeadWasSnapped) {
+        // Patch 15.11: pick whichever of the two colinear tangent directions actually points within
+        // the current mode's allowed half of the compass (see isNormalModeAngle()'s own doc comment).
+        // Since that allowed half and its "inverted" complement are two exact diametric halves, and
+        // tangentA/tangentB are themselves always exactly 180 degrees apart, exactly one of the two is
+        // ever compliant with the current mode - the other is always compliant with the opposite mode.
+        // This replaces the previous "shortest rotation from up (normal) / down (inverted)" heuristic
+        // (patch 15.5/15.6), which could pick a direction violating the mode's allowed half.
+        bool tangentAOk = inverted ? !isNormalModeAngle(tangentA) : isNormalModeAngle(tangentA);
+        chosen = tangentAOk ? tangentA : tangentB;
+    } else {
+        // Remains snapped: whichever of the two tangent directions is closest to the current
+        // orientation, so it never suddenly flips 180 degrees while being dragged along a line.
+        // Same rule regardless of inverted mode - only the initial choice above differs by mode.
+        double currentOrientation = normalizeAngle(this->rotation + rawTipAngle);
+        double diffA = std::abs(normalizeAngle(tangentA - currentOrientation));
+        double diffB = std::abs(normalizeAngle(tangentB - currentOrientation));
+        chosen = diffA <= diffB ? tangentA : tangentB;
+    }
+    this->rotation = chosen - rawTipAngle;
+    this->arrowHeadWasSnapped = true;
+}
+
+/**
+ * Patch 15.6: see this method's own doc comment in the header.
+ */
+auto EditSelection::toggleArrowHeadInvert() -> bool {
+    auto elements = this->getElementsView();
+    if (elements.size() != 1) {
+        return false;
+    }
+    // Patch 15.7: CORRECTIF - getElementsView()'s iterator actually yields "const Element*" (despite
+    // the container's own template argument saying "Element*" - the const-ness is propagated by the
+    // const-qualified accessor method itself), so a direct dynamic_cast<Stroke*> doesn't compile
+    // (casting away constness). The underlying Stroke is genuinely mutable here (this same object is
+    // freely mutated elsewhere, e.g. in finalizeSelection()), so a const_cast on top of a const
+    // dynamic_cast is safe and standard practice for this situation.
+    const auto* constStroke = dynamic_cast<const Stroke*>(*elements.begin());
+    auto* stroke = const_cast<Stroke*>(constStroke);
+    if (!stroke || !stroke->hasSnappableTip()) {
+        return false;
+    }
+    stroke->setArrowHeadInverted(!stroke->isArrowHeadInverted());
+    this->rotation = normalizeAngle(this->rotation + M_PI);
+    this->view->getXournal()->repaintSelection();
+    return true;
+}
